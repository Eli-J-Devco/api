<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="SolarEdge">
    <select id="getSolarEdgeInfo" resultType="com.nwm.api.entities.SiteEntity">
        SELECT
            id, solar_edge_id, solar_edge_api_key
        FROM site
        WHERE
            id = #{id}
            AND is_delete = 0
            AND status = 1
    </select>
</mapper>