    <insert id="saveConfig" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO api_access (
            id_user,
            created_date,
            updated_date
        )
        VALUES(
            ${employee_id},
            now(),
            now()
        );
        <selectKey keyProperty="id" resultType="int">
            SELECT
            LAST_INSERT_ID() as id
        </selectKey>
    </insert>

    <select id="checkUserHaveConfig" resultMap="ApiAccessMap">
        SELECT id FROM api_access WHERE id_user = ${employee_id}
    </select>

    <insert id="saveCompanyConfig">
        INSERT INTO api_access_company_map
            (id_api_access, id_company, status)
        VALUES
        <foreach collection="company" item="item" separator=",">
            (
                #{id},
                #{item.id},
                #{item.status}
            )
        </foreach>
    </insert>

    <insert id="saveSiteConfig">
        INSERT INTO api_access_site_map
        (id_api_access, id_site, status)
        VALUES
        <foreach collection="site" item="item" separator=",">
            (
            #{id},
            #{item.id},
            #{item.status}
            )
        </foreach>
    </insert>

    <update id="updateSecurityKey">
        UPDATE api_access SET security_key = #{security_key} AND updated_date = now() WHERE id_user = ${employee_id}
    </update>

    <delete id="deleteConfig">
        DELETE FROM ${table} WHERE id_api_access = ${id_api_access}
    </delete>
</mapper>