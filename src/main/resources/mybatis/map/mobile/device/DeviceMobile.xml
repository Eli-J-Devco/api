<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="DeviceMobile">
   <sql id="filterByDomain">
        AND ${column} IN(1,3,4,7,5)
   </sql>

   	<sql id="isCurrentValidCondition">
		(
			d.last_value IS NOT NULL
			AND d.last_value <![CDATA[ > ]]>  -2000 <!-- temporarily filter active power that doesn't make sense -->
			AND TIMESTAMPDIFF(MINUTE, d.last_updated, UTC_TIMESTAMP()) <![CDATA[ <= ]]> 30 <!-- if time difference is more than 30 minutes from last updated until now and value still exist mean that the device is not sending any data from last updated, so pretending its current value as null -->
		)
	</sql>

   <sql id="getActivePowerMeterSubquery">
        SELECT 
            d.id_site,
            IF(<include refid="DeviceMobile.isCurrentValidCondition"/>,d.last_value, NULL) AS activePower
        FROM device d
        WHERE 
            d.id_device_type IN(3,7,9) 
            AND d.is_excluded_meter = 0
			AND d.is_delete = 0
            AND d.`status` = 1 
            <include refid="DeviceMobile.filterByDomain">
                <property name="column" value="d.show_on_domain" />
            </include>
   </sql>

   <sql id="getActivePowerInverterSubquery">
        SELECT 
            d.id_site,
            IF(<include refid="DeviceMobile.isCurrentValidCondition"/>,d.last_value, NULL) AS activePower
        FROM device d
        WHERE 
            d.id_device_type = 1
			AND d.is_delete = 0
            AND d.`status` = 1 
            <include refid="DeviceMobile.filterByDomain">
                <property name="column" value="d.show_on_domain" />
            </include>
   </sql>

   <sql id="getActivePowerByVirtualDevicesSubquery">
		SELECT 
			d.id_site,
			IF(d.last_value <![CDATA[ > ]]>  0, IF(d.last_value <![CDATA[ < ]]> -2000, 0, d.last_value), NULL) AS activePower
		FROM
			device d
		WHERE
			d.id_device_type = 12
			<include refid="DeviceMobile.filterByDomain">
                <property name="column" value="d.show_on_domain" />
            </include>
	</sql>
</mapper>