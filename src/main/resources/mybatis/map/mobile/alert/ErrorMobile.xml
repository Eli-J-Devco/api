<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ErrorMobile">

    <resultMap id="ErrorTypeMap" type="com.nwm.api.entities.mobile.alert.ErrorTypeMobileEntity">
        <result property="id" column="id" />
        <result property="name" column="name"/>
    </resultMap>

    <select id="getErrorTypes" resultMap="ErrorTypeMap">
        select 
            e.id,
            e.name
        from error_type e
        where e.status = 1 and e.is_delete = 0
    </select>
</mapper>