<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Datalogger">
    <select id="getDataList" resultType="Map">
        SELECT
            id,
            serialnumber,
            ts,
            ts_real,
            modeup,
            logfile,
            note,
            sink_mqtt,
            sink_ftp,
            sink_http,
            sink_https,
            sink_kafka,
            sink_influxdb,
            telemetry,
            modbusdevicenumber
        FROM ${databaseName}

        <where>
            <choose>
                <when test="isFirstRun">
                    is_insert_completed IS DISTINCT FROM false
                </when>
                <otherwise>
                    is_insert_completed = false
                </otherwise>
            </choose>
        </where>

        ORDER BY ts_real ASC
        LIMIT #{limit}
    </select>

    <update id="updateDataStatus">
        UPDATE ${databaseName}
        SET is_insert_completed = #{isInsertCompleted}
        WHERE id = #{logId}
    </update>

    <delete id="deleteData">
        DELETE FROM ${databaseName}
        WHERE id = #{logId}
    </delete>
</mapper>
