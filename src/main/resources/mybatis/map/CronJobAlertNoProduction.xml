	<select id="checkExitsAlert" resultType="com.nwm.api.entities.AlertEntity">
		SELECT
			a.id,
			a.id_device,
			a.start_date,
			a.end_date
		FROM
			`alert` a 
		WHERE
			a.id_device = #{id_device} 
			AND a.id_error = #{id_error}
			AND a.`status` = 1 
			AND a.is_delete = 0 
			AND a.start_date IS NOT NULL 
			AND a.end_date IS NULL 
			LIMIT 1
	</select>
	
	
	<select id="getDataloggerItem" resultType="com.nwm.api.entities.BatchJobTableEntity">
		SELECT
			IFNULL( m.id_device, 0 ) AS id_device,
			IFNULL((
				SELECT
					time 
				FROM
					${datatablename} 
				ORDER BY
					time DESC 
					LIMIT 1 
					),
				DATE_ADD( NOW(), INTERVAL - 2 HOUR ) 
			) AS start_date,
			MAX( m.time ) AS end_date 
		FROM
			${datatablename} m 
		WHERE
			m.time <![CDATA[>=]]>  DATE_ADD( NOW(), INTERVAL -2 HOUR ) 
			LIMIT 1
	</select>
	
	
	
	<select id="findEndDateNoProduction" resultType="com.nwm.api.entities.BatchJobTableEntity">
		SELECT 
			COALESCE(
			    (
			    	SELECT dv.time
					FROM ${datatablename} dv
					LEFT JOIN device d ON d.id = dv.id_device
					LEFT JOIN site s ON s.id = d.id_site
					LEFT JOIN time_zone t ON t.id = s.id_time_zone
					WHERE dv.nvmActivePower IS NOT NULL AND dv.nvmActivePower != 0
					AND HOUR(CONVERT_TZ(dv.time, 'UTC', t.value))  <![CDATA[>=]]> s.cf_start_time 
					AND HOUR(CONVERT_TZ(dv.time, 'UTC', t.value)) <![CDATA[<=]]> s.cf_end_time
					ORDER BY dv.time DESC
					LIMIT 1
			    ), NULL
			) AS end_date;
	</select>
	
	
	
	<select id="checkAlertQueueExits" resultType="com.nwm.api.entities.AlertEntity">
		(SELECT
				a.id_device,
				a.id_error,
				a.start_date,
				a.end_date
			FROM
				`alert` a 
			WHERE
				a.id_device = #{id_device}
				AND a.id_error = #{id_error}
				AND a.`status` = 1 
				AND a.is_delete = 0 
				AND a.start_date IS NOT NULL 
				AND (a.end_date IS NULL OR a.start_date = #{start_date} )
				LIMIT 1)
				
		UNION ALL
				(
				SELECT
				a.id_device,
				a.id_error,
				a.start_date,
				a.end_date
			FROM
				`alert_queue` a 
			WHERE
				a.id_device = #{id_device}
				AND a.id_error = #{id_error}
				AND a.`status` = 1 
				AND a.is_delete = 0 
				AND a.start_date IS NOT NULL 
				AND a.end_date IS NULL 
				AND (a.is_queue = 0 OR a.start_date = #{start_date})
				LIMIT 1)
	</select>
	
